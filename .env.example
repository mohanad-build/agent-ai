# Anthropic
ANTHROPIC_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://YOUR-RAILWAY-DOMAIN/onboard/oauth/callback

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public base URL of this app (no trailing slash). Used to validate inbound
# Twilio SMS webhook signatures against the exact URL Twilio signed, instead
# of reconstructing it from the request, which can pick up the wrong scheme
# behind a proxy. If unset, falls back to reconstructing from the request.
PUBLIC_APP_URL=https://app.getklosed.ca

# Dashboard auth
DASHBOARD_PASSWORD=
SESSION_SECRET=

# Optional: override agent processing (leave blank in production)
AGENT_ID=
MOCK_NOW=
WEBHOOK_SKIP_SIGNATURE_CHECK=false
WEBHOOK_PORT=3000

# Filesystem root for persistent storage (agent files, content
# engine data). Defaults to process.cwd() if unset. On Railway
# this is set to the Volume mount path.
STORAGE_ROOT=
