node_modules/
.env

# OAuth credentials (Google client secret JSON)
client_secret_*.json
credentials.json
token.json

# Agent refresh tokens (per-agent OAuth tokens)
agents/*.json
!agents/.gitkeep
!agents/example.json

# Agent state files (runtime state, not committed)
agents/*.state.json

# Operator runtime configs (per-operator OAuth tokens)
operators/*.json
!operators/example.json

# Operator state files (runtime state, not committed)
operators/*.state.json

# OS / editor noise
.DS_Store
*.log
.vscode/
.idea/
