node_modules/
.env

# OAuth credentials (Google client secret JSON)
client_secret_*.json
credentials.json
token.json

# Agent refresh tokens (per-agent OAuth tokens)
agents/*.json
!agents/.gitkeep
!agents/example.json

# Agent state files (runtime state, not committed)
agents/*.state.json

# Operator runtime configs (per-operator OAuth tokens)
operators/*.json
!operators/example.json

# Operator state files (runtime state, not committed)
operators/*.state.json

# OS / editor noise
.DS_Store
*.log
.vscode/
.idea/

# Content Engine data cache (runtime data, do not commit)
data/market/**/*.json
data/market/**/*.jsonl
!data/market/.gitkeep

# HARD GATE 7 calibration baselines (local working evidence, recreated via scripts/calibration-7-11-8.js)
calibration-archive/

# HARD GATE follow-up/path1a prompt iteration baselines (local working evidence, recreated via scripts/iterate-prompts.js)
prompt-iteration-archive/
